# Postgres connection string (Neon or any Postgres). Required.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Signs auth JWTs. Required in production — the code falls back to an
# insecure dev default if unset, which is fine for local dev only.
JWT_SECRET=change-me-to-a-long-random-string

# CORS. "*" for local dev; set to your deployed frontend origin in production.
ALLOWED_ORIGINS=*

# Optional: enables higher-fidelity common-database search counts (footprint
# stage) instead of the free DuckDuckGo backend.
# SERPAPI_API_KEY=

# Optional: enables the Google Places enricher (discovery/places.py).
# GOOGLE_PLACES_API_KEY=

# Optional: only needed to LLM-generate profiles (discovery/profile.py) instead
# of the offline template.
# ANTHROPIC_API_KEY=

# Optional: only needed to actually SEND the Avalanche publish transaction
# (discovery/onchain.py) — dry-run root computation works without these.
# AVALANCHE_RPC_URL=https://api.avax-test.network/ext/bc/C/rpc
# PRIVATE_KEY=
# REGISTRY_ADDRESS=
